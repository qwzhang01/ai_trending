# ============================================
# AI Trending — 环境变量配置
# ============================================

# LLM 配置
# 支持的格式: openai/gpt-4o, anthropic/claude-sonnet-4-20250514, ollama/llama3.1 等
MODEL=openai/gpt-4o
OPENAI_API_KEY=your_openai_api_key_here

# 自定义 API Base（Ollama / 代理等）
# OPENAI_API_BASE=http://localhost:11434

# 如果使用 Anthropic:
# MODEL=anthropic/claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-xxx

# LLM 行为控制（生产环境推荐低温度）
LLM_TEMPERATURE=0.1

# 分级模型（成本优化）
# 数据采集/整理类任务用便宜模型，写作任务用好模型
# 未设置则全部回退到 MODEL
MODEL_LIGHT=openai/gpt-4o-mini

# ============================================
# GitHub 配置
# ============================================

# GitHub Token — 用于访问 GitHub API
# 获取方式: https://github.com/settings/tokens
# 推荐创建 Fine-grained token，需要权限:
#   - public_repo (搜索公开仓库)
#   - contents:write (推送报告到仓库)
GITHUB_TOKEN=your_github_token_here

# 报告推送目标仓库（格式: owner/repo-name）
GITHUB_REPORT_REPO=your-username/ai-trending-reports

# ============================================
# 新闻 API（可选）
# ============================================

# newsdata.io — 提供更多新闻源
# 免费注册获取: https://newsdata.io/register
# 注意: 免费版不支持 timeframe/removeduplicate 等高级参数
NEWSDATA_API_KEY=your_newsdata_api_key_here
# ============================================
# 知乎配置（可选）
# ============================================

# 知乎 Cookie — 用于获取知乎热榜 AI 相关内容
# 获取方式: 浏览器登录知乎 → F12 → Network → 复制 Cookie 请求头
# 不设置则会尝试从页面 SSR 提取数据（成功率较低）
# ZHIHU_COOKIE=your_zhihu_cookie_here

# ============================================
# 运行配置
# ============================================

# 作者名称（显示在报告中）
AUTHOR_NAME=AI Trending Bot

# Crew 详细日志
CREW_VERBOSE=true

# HTTP 请求重试次数和超时（秒）
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# 关闭 CrewAI Tracing 提示
CREWAI_TRACING_ENABLED=false

# 推理模型 thinking 模式（Kimi-K2.5、DeepSeek-R1 等推理模型需要设为 true）
# 这些模型默认开启 thinking，但 CrewAI 多轮对话不兼容，会报 reasoning_content 缺失
# LLM_DISABLE_THINKING=true

# ============================================
# 可观测性 — Webhook 通知（可选）
# ============================================

# 运行失败时自动发送通知
# 支持：企业微信、飞书、钉钉、Slack 机器人
# 留空则不发通知

# 企业微信机器人:
# WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# 飞书机器人:
# WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 钉钉机器人:
# WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# Slack Webhook:
# WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# 成功时也发通知（默认只在失败时发）
# WEBHOOK_ON_SUCCESS=true

# ============================================
# 微信配置（可选）
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here
WECHAT_THUMB_MEDIA_ID=your_wechat_thumb_media_id_here